        }),
      })

      local ok_cmp_lsp, cmp_lsp = pcall(require, "cmp_nvim_lsp")
      local capabilities = ok_cmp_lsp and cmp_lsp.default_capabilities() or vim.lsp.protocol.make_client_capabilities()

      vim.api.nvim_create_autocmd("LspAttach", {
        callback = function(ev)
          local opts = { buffer = ev.buf, silent = true }
          vim.keymap.set("n", "K", vim.lsp.buf.hover, opts)
          vim.keymap.set("n", "gd", vim.lsp.buf.definition, opts)
          vim.keymap.set("n", "gr", vim.lsp.buf.references, opts)
          vim.keymap.set("n", "gi", vim.lsp.buf.implementation, opts)
          vim.keymap.set("n", "<leader>rn", vim.lsp.buf.rename, opts)
          vim.keymap.set("n", "<leader>ca", vim.lsp.buf.code_action, opts)
          vim.keymap.set("n", "<leader>f", function() vim.lsp.buf.format({ async = true }) end, opts)
        end,
      })

      local function setup_lsp(server, cfg)
        cfg = cfg or {}
        cfg.capabilities = vim.tbl_deep_extend("force", {}, capabilities, cfg.capabilities or {})
        local has_new = type(vim.lsp) == "table" and type(vim.lsp.config) == "function" and type(vim.lsp.enable) == "function"
        if has_new then
          vim.lsp.config(server, cfg)
          vim.lsp.enable(server)
        else
          local ok_lspconfig, lspconfig = pcall(require, "lspconfig")
          if ok_lspconfig and lspconfig[server] then
            lspconfig[server].setup(cfg)
          end
        end
      end

      -- Generic servers
      local servers = {
        "bashls",
        "csharp_ls",
        "pyright",
        "jsonls",
        "yamlls",
        "taplo",
        "lemminx",
        "dockerls",
        "docker_compose_language_service",
        "sqls",
        "marksman",
      }
      for _, s in ipairs(servers) do
        setup_lsp(s)
      end

      -- Lua (Neovim globals)
      setup_lsp("lua_ls", {
        settings = {
          Lua = {
            diagnostics = { globals = { "vim" } },
            workspace = { checkThirdParty = false },
            telemetry = { enable = false },
          },
        },
      })

      -- PowerShell (works when Mason installs package)
      local ps_bundle = vim.fn.stdpath("data") .. "/mason/packages/powershell-editor-services"
      if vim.fn.isdirectory(ps_bundle) == 1 then
        setup_lsp("powershell_es", {
          bundle_path = ps_bundle,
          filetypes = { "ps1", "psm1", "psd1" },
          init_options = { enableProfileLoading = false },
        })
      end
    end,
  },
})
LUA

  install -m 0644 /tmp/init.lua.nvimfix.$$ "$NVIM_CONFIG_DIR/init.lua"
  rm -f /tmp/init.lua.nvimfix.$$
  chown "$USER_NAME:$USER_NAME" "$NVIM_CONFIG_DIR/init.lua" || true
}

check_nvim() {
  if ! have_cmd nvim; then
    if [[ "$INSTALL_NVIM" -eq 1 ]]; then
      install_packages
    else
      err "Neovim (nvim) is not installed."
      err "Re-run with: bash fix-neovim.sh --install-nvim"
      exit 1
    fi
  fi

  local ver_line ver
  ver_line="$(nvim --version | head -n1 || true)"
  ver="$(echo "$ver_line" | sed -E 's/.*NVIM v([0-9]+\.[0-9]+\.[0-9]+).*/\1/' || true)"
  log "Detected: ${ver_line:-unknown}"
  if [[ -n "$ver" ]] && ! version_ge "$ver" "0.9.0"; then
    warn "Neovim $ver is quite old. 0.10+ (ideally 0.11+) is recommended."
    if [[ "$INSTALL_NVIM" -eq 1 ]]; then
      install_packages || true
    fi
  fi
}

install_plugins_headless() {
  log "Installing/updating plugins headlessly with Lazy..."
  run_as_user "nvim --headless '+Lazy! sync' +qa" || true

  log "Updating Tree-sitter parsers..."
  run_as_user "nvim --headless '+TSUpdateSync' +qa" || true
}

final_checks() {
  log "Verifying plugin folders..."
  run_as_user "ls -la '$NVIM_DATA_DIR/lazy' || true"
  run_as_user "ls -la '$NVIM_DATA_DIR/lazy/nvim-treesitter' || true"

  cat <<EOF

================ DONE ================
Try this now:

  nvim

Then inside Neovim run:
  :Lazy
  :Mason
  :LspInfo
  :checkhealth
  :TSUpdate

Test files:
  test.sh      (bash)
  Program.cs   (C#)
  schema.sql   (SQL)
  docker-compose.yml
  appsettings.json
  config.yaml

Autocomplete:
  Ctrl-Space   open suggestions
  Ctrl-n/p     next/prev
  Enter        confirm

If something still fails, paste:
  nvim --version | head -n1
  ls -la ~/.local/share/nvim/lazy/
  ls -la ~/.local/share/nvim/lazy/nvim-treesitter

Backup created at:
  $BACKUP_ROOT
======================================
EOF
}

main() {
  log "Starting Neovim repair/reset..."
  if [[ "$(id -u)" -ne 0 ]] && ! have_cmd sudo; then
    err "This script needs sudo available to fix ownership/permissions."
    exit 1
  fi

  if [[ "$(id -u)" -eq 0 ]]; then
    warn "Running as root. That's okay, but it will repair files for user: $USER_NAME"
  fi

  if [[ "$INSTALL_NVIM" -eq 1 ]]; then
    install_packages || true
  fi

  check_nvim
  fix_permissions
  backup_existing
  clean_broken_state
  write_init_lua
  fix_permissions
  install_plugins_headless
  final_checks
}
