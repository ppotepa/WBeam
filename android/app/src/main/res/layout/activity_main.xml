<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617">

    <SurfaceView
        android:id="@+id/previewSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/cursorOverlay"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/cursor_overlay_dot"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="end"
        android:orientation="horizontal"
        android:padding="10dp">

        <Button
            android:id="@+id/settingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:alpha="0.92"
            android:text="Settings" />

        <Button
            android:id="@+id/logButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:alpha="0.92"
            android:text="Log" />

        <Button
            android:id="@+id/fullscreenButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.92"
            android:text="Fullscreen" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/quickActionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="10dp"
        android:layout_marginTop="62dp"
        android:layout_marginEnd="10dp"
        android:background="#CC0B1220"
        android:orientation="horizontal"
        android:padding="6dp">

        <Button
            android:id="@+id/quickStartButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start" />

        <Button
            android:id="@+id/quickStopButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="Stop" />

        <Button
            android:id="@+id/quickTestButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="Bandwidth Test" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/debugInfoPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="10dp"
        android:layout_marginTop="112dp"
        android:layout_marginEnd="10dp"
        android:background="#80131C2E"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/debugInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="debug overlay"
            android:textColor="#E2E8F0"
            android:textSize="12sp" />

        <com.wbeam.widget.FpsLossGraphView
            android:id="@+id/debugFpsGraph"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/statusPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="10dp"
        android:background="@drawable/status_panel_bg"
        android:orientation="horizontal"
        android:padding="10dp">

        <View
            android:id="@+id/statusLed"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/status_led_bg" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IDLE"
                android:textColor="#E2E8F0"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="tap Start Live View"
                android:textColor="#CBD5E1"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/bpsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="throughput: -"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/statsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="fps in/out: - | drops: - | reconnects: -"
                android:textColor="#7DD3FC"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/liveLogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#0B1220"
                android:fontFamily="monospace"
                android:maxLines="7"
                android:padding="6dp"
                android:text="live debug log..."
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/perfHudPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top"
        android:background="@android:color/transparent"
        android:padding="0dp">

        <WebView
            android:id="@+id/perfHudWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/perfHudText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:lineSpacingExtra="1dp"
            android:text="HUD OFFLINE"
            android:textColor="#B3EAF4FF"
            android:textSize="9sp" />
    </FrameLayout>

    <!-- ── Startup / preflight full-screen modal ─────────────────────────── -->
    <FrameLayout
        android:id="@+id/preflightOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE020617"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="28dp"
            android:background="#F0111827"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- header -->
            <TextView
                android:id="@+id/startupTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="WBEAM"
                android:textColor="#F8FAFC"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/startupSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="startup sequence"
                android:textColor="#475569"
                android:textSize="11sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="14dp"
                android:background="#1E293B" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/startupStep1Row"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/startup_step_card_bg"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/startupStep1Badge"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="#1E293B"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:text="⇄"
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/startupStep1Status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="monospace"
                            android:text="WAIT"
                            android:textColor="#64748B"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/startupStep1Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:text="CONTROL"
                        android:textColor="#CBD5E1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/startupStep1Detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:maxLines="3"
                        android:text="polling control api..."
                        android:textColor="#94A3B8"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:fontFamily="monospace"
                    android:text="→"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/startupStep2Row"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/startup_step_card_bg"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/startupStep2Badge"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="#1E293B"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:text="⚙"
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/startupStep2Status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="monospace"
                            android:text="WAIT"
                            android:textColor="#64748B"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/startupStep2Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:text="HANDSHAKE"
                        android:textColor="#CBD5E1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/startupStep2Detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:maxLines="3"
                        android:text="waiting for control link"
                        android:textColor="#94A3B8"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:fontFamily="monospace"
                    android:text="→"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/startupStep3Row"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/startup_step_card_bg"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/startupStep3Badge"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="#1E293B"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:text="▶"
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/startupStep3Status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="monospace"
                            android:text="WAIT"
                            android:textColor="#64748B"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/startupStep3Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:text="STREAM"
                        android:textColor="#CBD5E1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/startupStep3Detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:maxLines="3"
                        android:text="waiting for handshake"
                        android:textColor="#94A3B8"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="12dp"
                android:background="#1E293B" />

            <TextView
                android:id="@+id/startupInfoText"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="#0B1322"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:padding="10dp"
                android:scrollbars="vertical"
                android:text="api=... impl=..."
                android:textColor="#CBD5E1"
                android:textIsSelectable="true"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/startupBuildVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="monospace"
            android:text="build -"
            android:textColor="#64748B"
            android:textSize="10sp" />
    </FrameLayout>

    <ScrollView
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#F2131C2E"
        android:elevation="12dp"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="WBeam Settings"
                    android:textColor="#F8FAFC"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/settingsCloseButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Close" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/modeLowLatencyButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LOW LAT"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/modeSmoothButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="SMOOTH"
                    android:textAllCaps="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/qualityLowButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LOW"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/qualityMedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="MED"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/qualityHighButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="HIGH"
                    android:textAllCaps="true" />
            </LinearLayout>

            <Button
                android:id="@+id/advancedToggleButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="▶ Advanced"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/advancedPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Profile"
                android:textColor="#CBD5E1" />

            <Spinner
                android:id="@+id/profileSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Encoder"
                android:textColor="#CBD5E1" />

            <Spinner
                android:id="@+id/encoderSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/intraOnlyButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="All-Intra: OFF"
                android:textAllCaps="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Host Cursor Mode"
                android:textColor="#CBD5E1" />

            <Spinner
                android:id="@+id/cursorSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/resolutionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Resolution Scale"
                    android:textColor="#CBD5E1" />

                <TextView
                    android:id="@+id/resValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E2E8F0" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/resolutionSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FPS"
                    android:textColor="#CBD5E1" />

                <TextView
                    android:id="@+id/fpsValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E2E8F0" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/fpsSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="72" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quality / Bitrate"
                    android:textColor="#CBD5E1" />

                <TextView
                    android:id="@+id/bitrateValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E2E8F0" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/bitrateSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="295" />

            <Button
                android:id="@+id/cursorOverlayButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Local Cursor Overlay ON" />

            <LinearLayout
                android:id="@+id/debugControlsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/startButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Live" />

                <Button
                    android:id="@+id/stopButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Stop" />
            </LinearLayout>

            <Button
                android:id="@+id/testButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Bandwidth Test (hold: video test)"
                android:visibility="gone" />

            <Button
                android:id="@+id/applySettingsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#16A34A"
                android:text="Apply &amp; Restart Stream"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/hostHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#93C5FD"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/simpleMenuPanel"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC131C2E"
        android:elevation="14dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WBeam Quick Menu"
            android:textColor="#F8FAFC"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mode"
            android:textColor="#CBD5E1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/simpleModeH265Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="H265" />

            <Button
                android:id="@+id/simpleModeRawButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="RAW" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="FPS"
            android:textColor="#CBD5E1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/simpleFps30Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="30" />

            <Button
                android:id="@+id/simpleFps45Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="45" />

            <Button
                android:id="@+id/simpleFps60Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="60" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/simpleFps90Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="90" />

            <Button
                android:id="@+id/simpleFps120Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="120" />

            <Button
                android:id="@+id/simpleFps144Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="144" />
        </LinearLayout>

        <Button
            android:id="@+id/simpleApplyButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#16A34A"
            android:text="Apply &amp; Start"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</FrameLayout>
