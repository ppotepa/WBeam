{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WBeam Desktop Tauri",
  "version": "0.1.0",
  "identifier": "com.wbeam.desktop.tauri",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WBeam Desktop (Tauri Preview)",
        "width": 1540,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
