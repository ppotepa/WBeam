#!/usr/bin/env bash
set -euo pipefail

X11_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST_MANIFEST="$X11_DIR/host/Cargo.toml"
DEFAULT_STREAM_PORT="${WBEAM_X11_STREAM_PORT:-5002}"
POLICY_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/wbeam"
POLICY_FILE="${POLICY_DIR}/x11-virtual-policy.conf"

usage() {
  cat <<USAGE
WBeam proto_x11 launcher

Usage:
  ./proto_x11/run <command> [args]

Commands:
  probe-host | doctor | status | start | stop | smoke | acceptance
  android-build | android-deploy
  service-status | service-restart | logs

Examples:
  ./proto_x11/run doctor --serial HVA6PKNT --stream-port 5002
  ./proto_x11/run start --serial HVA6PKNT
  ./proto_x11/run acceptance --serial HVA6PKNT
  ./proto_x11/run stop --serial HVA6PKNT
USAGE
}

sanitize_user_service_env() {
  local unit_file="${HOME}/.config/systemd/user/wbeam-daemon.service"
  if [[ ! -f "$unit_file" ]]; then
    return 0
  fi
  if ! grep -Eq '^Environment=(DISPLAY|XAUTHORITY|WAYLAND_DISPLAY)=' "$unit_file"; then
    return 0
  fi
  cp "$unit_file" "${unit_file}.bak"
  sed -i -E '/^Environment=(DISPLAY|XAUTHORITY|WAYLAND_DISPLAY)=/d' "$unit_file"
  systemctl --user daemon-reload
  echo "[proto_x11] sanitized stale X11 env in user service unit"
}

require_host_manifest() {
  if [[ ! -f "$HOST_MANIFEST" ]]; then
    echo "[proto_x11] missing host manifest: $HOST_MANIFEST" >&2
    exit 1
  fi
}

has_opt() {
  local needle="$1"; shift
  local arg
  for arg in "$@"; do
    if [[ "$arg" == "$needle" || "$arg" == "$needle="* ]]; then
      return 0
    fi
  done
  return 1
}

configure_x11_virtual_policy() {
  local enable_setmonitor=0
  local allow_monitor=0
  local disable_real=0

  local has_nvidia=0
  local has_evdi=0
  if command -v lspci >/dev/null 2>&1; then
    if lspci -k 2>/dev/null | rg -qi "Kernel driver in use:\\s*nvidia"; then
      has_nvidia=1
    fi
  fi
  if command -v lsmod >/dev/null 2>&1; then
    if lsmod 2>/dev/null | rg -q '^evdi\\s'; then
      has_evdi=1
    fi
  fi

  if [[ "$has_nvidia" == "1" && "$has_evdi" == "1" ]]; then
    enable_setmonitor=1
    allow_monitor=1
    disable_real=1
    echo "[proto_x11] detected NVIDIA + EVDI; forcing monitor-object fallback safety"
  fi

  mkdir -p "$POLICY_DIR"
  cat >"$POLICY_FILE" <<EOF
# Generated by proto_x11/run
ENABLE_SETMONITOR_FALLBACK=${enable_setmonitor}
ALLOW_MONITOR_OBJECT=${allow_monitor}
DISABLE_REAL_OUTPUT_BACKEND=${disable_real}
EOF
  echo "[proto_x11] wrote virtual policy config: $POLICY_FILE"
}

sync_daemon_virtual_policy() {
  local cmd="${1:-}"
  if ! command -v systemctl >/dev/null 2>&1; then
    return 0
  fi

  systemctl --user unset-environment \
    WBEAM_X11_ENABLE_SETMONITOR_FALLBACK \
    WBEAM_X11_ALLOW_MONITOR_OBJECT \
    WBEAM_X11_DISABLE_REAL_OUTPUT_BACKEND || true
  if [[ "$cmd" == "start" || "$cmd" == "smoke" || "$cmd" == "acceptance" ]]; then
    echo "[proto_x11] cleared old systemd user env keys for X11 virtual backend policy"
  fi
}

auto_serial() {
  if ! command -v adb >/dev/null 2>&1; then
    echo "[proto_x11] adb not found; pass --serial explicitly" >&2
    exit 1
  fi
  local rows
  rows="$(adb devices | awk '$2=="device" {print $1}')"
  local count
  count="$(printf '%s\n' "$rows" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "$count" == "0" ]]; then
    echo "[proto_x11] no adb devices in 'device' state; pass --serial <SERIAL>" >&2
    exit 1
  fi
  if [[ "$count" != "1" ]]; then
    echo "[proto_x11] multiple adb devices; pass --serial <SERIAL> explicitly" >&2
    printf '%s\n' "$rows" >&2
    exit 1
  fi
  printf '%s\n' "$rows"
}

inject_session_args_if_needed() {
  local cmd="$1"; shift
  local -a args=("$@")

  case "$cmd" in
    start|stop|smoke|acceptance)
      if ! has_opt "--serial" "${args[@]}"; then
        args+=("--serial" "$(auto_serial)")
      fi
      if ! has_opt "--stream-port" "${args[@]}"; then
        args+=("--stream-port" "$DEFAULT_STREAM_PORT")
      fi
      ;;
  esac

  printf '%s\n' "${args[@]}"
}

main() {
  local cmd="${1:-help}"
  if [[ "$#" -gt 0 ]]; then
    shift
  fi

  require_host_manifest

  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    probe|probe-host)
      configure_x11_virtual_policy
      sync_daemon_virtual_policy "$cmd"
      exec cargo run --manifest-path "$HOST_MANIFEST" -- probe-host "$@"
      ;;
    doctor|status|start|stop|smoke|acceptance)
      mapfile -t args < <(inject_session_args_if_needed "$cmd" "$@")
      configure_x11_virtual_policy
      sync_daemon_virtual_policy "$cmd"
      exec cargo run --manifest-path "$HOST_MANIFEST" -- "$cmd" "${args[@]}"
      ;;
    android-build)
      exec "$X11_DIR/android/build_x11_apk.sh" "$@"
      ;;
    android-deploy)
      exec "$X11_DIR/android/deploy_x11.sh" "$@"
      ;;
    service-status)
      exec systemctl --user status wbeam-daemon.service --no-pager -l
      ;;
    service-restart)
      sanitize_user_service_env
      systemctl --user restart wbeam-daemon.service
      exec systemctl --user status wbeam-daemon.service --no-pager -l
      ;;
    logs)
      exec journalctl --user -u wbeam-daemon.service -f
      ;;
    *)
      echo "[proto_x11] unknown command: $cmd" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
