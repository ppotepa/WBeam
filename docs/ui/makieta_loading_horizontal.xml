<?xml version="1.0" encoding="utf-8"?>
<!--
  Makieta ekranu loading/connect:
  - 3 kafelki poziomo (krok 1, 2, 3) + strzalki
  - dolny panel status/error
  - kazda ikonka wspiera 3 tinty statusu:
      zielony    -> OK
      pomarancz  -> IN PROGRESS
      czerwony   -> ERROR
  To jest mock layout do wdrozenia w android/app/.../activity_main.xml.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <TextView
        android:id="@+id/loadingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="WBeam Connect"
        android:textColor="#E2E8F0"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/stepsRow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="16dp"
        android:layout_weightSum="3"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/logPanel"
        app:layout_constraintDimensionRatio="H,3:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loadingTitle">

        <LinearLayout
            android:id="@+id/stepCard1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="6dp"
            android:layout_weight="1"
            android:background="@android:color/darker_gray"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:id="@+id/stepIcon1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:tint="#F59E0B"
                android:src="@android:drawable/presence_online" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="1. Control Link"
                android:textColor="#E2E8F0"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="→"
            android:textColor="#93A6C7"
            android:textSize="24sp" />

        <LinearLayout
            android:id="@+id/stepCard2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="6dp"
            android:layout_weight="1"
            android:background="@android:color/darker_gray"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:id="@+id/stepIcon2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:tint="#22C55E"
                android:src="@android:drawable/stat_notify_sync" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="2. Handshake"
                android:textColor="#E2E8F0"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="→"
            android:textColor="#93A6C7"
            android:textSize="24sp" />

        <LinearLayout
            android:id="@+id/stepCard3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="6dp"
            android:layout_weight="1"
            android:background="@android:color/darker_gray"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:id="@+id/stepIcon3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:tint="#EF4444"
                android:src="@android:drawable/stat_sys_download_done" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="3. Streaming"
                android:textColor="#E2E8F0"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/logPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="#111C31"
        android:orientation="vertical"
        android:padding="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.30"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status / Error Log"
            android:textColor="#A5B4CF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Legenda: zielony=OK, pomarancz=IN PROGRESS, czerwony=ERROR"
            android:textColor="#8FA4C4"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/loadingLogText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="[1] Control Link: OK\n[2] Handshake: in progress...\n[3] Streaming: waiting for frames..."
            android:textColor="#D4DEEF"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
