{
  "version": 1,
  "rules": [
    {
      "name": "legacy_api17",
      "when": { "sdk_int_lte": 17 },
      "result": {
        "profile": "API17_SAFE_60FPS_BALANCED",
        "reason": "legacy decoder/transport compatibility"
      }
    },
    {
      "name": "default_modern",
      "when": { "sdk_int_gte": 18 },
      "result": {
        "profile": "AUTO_60FPS_BALANCED",
        "reason": "default modern path"
      }
    }
  ]
}
