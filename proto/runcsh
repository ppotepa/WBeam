#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
HOST_CS_DIR="$ROOT_DIR/host-cs"
PROJECT="$HOST_CS_DIR/ProtoHostCs.csproj"
RUNNER="$HOST_CS_DIR/host-cs.sh"

dotnet build -c Release "$PROJECT"

export CARGO_BIN="$RUNNER"
: "${PROTO_H264:=1}"
: "${PROTO_H264_SOURCE_FRAMED:=1}"

exec "$ROOT_DIR/run.sh" "$@"
