#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
DURATION_SECS="${1:-45}"
PRESET="${2:-fast}"
STAMP="$(date +%Y%m%d-%H%M%S)"
RUN_LOG="/tmp/proto-cs-run-${STAMP}.log"
ANDROID_LOG="/tmp/proto-android-${STAMP}.log"
PORTAL_LOG="/tmp/proto-portal-streamer.log"

if ! [[ "$DURATION_SECS" =~ ^[0-9]+$ ]] || [[ "$DURATION_SECS" -lt 5 ]]; then
  echo "[bench-csh] duration must be integer >= 5 seconds"
  exit 1
fi

echo "[bench-csh] running C# backend benchmark: ${DURATION_SECS}s preset=${PRESET}"
echo "[bench-csh] run log: ${RUN_LOG}"
echo "[bench-csh] android log: ${ANDROID_LOG}"

(
  cd "$ROOT_DIR"
  PROTO_ANDROID_LOGCAT=1 \
  ANDROID_LOG_FILE="$ANDROID_LOG" \
  timeout "${DURATION_SECS}" ./runcsh "$PRESET" >"$RUN_LOG" 2>&1 || true
)

echo "[bench-csh] benchmark finished, parsing metrics..."

host_samples="$(grep -c "\\[proto-cs\\] WBH1 stats:" "$RUN_LOG" || true)"
if [[ "$host_samples" -gt 0 ]]; then
  awk '
    /\[proto-cs\] WBH1 stats:/ {
      n++
      if (match($0, /fps=[0-9.]+/)) {
        fps = substr($0, RSTART + 4, RLENGTH - 4) + 0
        sum_fps += fps
      }
      if (match($0, /avg_kb=[0-9]+/)) {
        kb = substr($0, RSTART + 7, RLENGTH - 7) + 0
        sum_kb += kb
      }
      if (match($0, /units=[0-9]+/)) {
        u = substr($0, RSTART + 6, RLENGTH - 6) + 0
        sum_units += u
      }
    }
    END {
      if (n > 0) {
        printf("[bench-csh] host-cs samples=%d avg_fps=%.2f avg_kb=%d avg_units=%d\n",
               n, sum_fps / n, int(sum_kb / n), int(sum_units / n))
      }
    }
  ' "$RUN_LOG"
else
  echo "[bench-csh] no host-cs stat samples found"
fi

if [[ -f "$PORTAL_LOG" ]]; then
  portal_samples="$(grep -c "\\[wbeam-framed\\] pipeline_fps=" "$PORTAL_LOG" || true)"
  if [[ "$portal_samples" -gt 0 ]]; then
    awk '
      /\[wbeam-framed\] pipeline_fps=/ {
        n++
        if (match($0, /pipeline_fps=[0-9]+/)) {
          p = substr($0, RSTART + 13, RLENGTH - 13) + 0
          sum_p += p
        }
        if (match($0, /sender_fps=[0-9.]+/)) {
          s = substr($0, RSTART + 11, RLENGTH - 11) + 0
          sum_s += s
        }
      }
      END {
        if (n > 0) {
          printf("[bench-csh] portal samples=%d avg_pipeline_fps=%.2f avg_sender_fps=%.2f\n",
                 n, sum_p / n, sum_s / n)
        }
      }
    ' "$PORTAL_LOG"
  else
    echo "[bench-csh] no portal framed samples found in ${PORTAL_LOG}"
  fi
else
  echo "[bench-csh] portal log not found (${PORTAL_LOG})"
fi

if [[ -f "$ANDROID_LOG" ]]; then
  android_samples="$(grep -c "H264 [0-9.].*fps drop=" "$ANDROID_LOG" || true)"
  if [[ "$android_samples" -gt 0 ]]; then
    awk '
      /H264 [0-9.].*fps drop=/ {
        n++
        if (match($0, /H264 [0-9.]+ fps/)) {
          f = substr($0, RSTART + 5, RLENGTH - 9) + 0
          sum_f += f
        }
        if (match($0, /drop=[0-9]+/)) {
          d = substr($0, RSTART + 5, RLENGTH - 5) + 0
          sum_d += d
        }
      }
      END {
        if (n > 0) {
          printf("[bench-csh] android samples=%d avg_decode_fps=%.2f avg_drop=%d\n",
                 n, sum_f / n, int(sum_d / n))
        }
      }
    ' "$ANDROID_LOG"
  else
    echo "[bench-csh] no android H264 fps samples found in ${ANDROID_LOG}"
  fi
else
  echo "[bench-csh] android log not found (${ANDROID_LOG})"
fi

echo "[bench-csh] done"
