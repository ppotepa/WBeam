<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/connectionLostDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:background="@drawable/connection_lost_dot"
        android:visibility="gone" />

    <TextView
        android:id="@+id/renderErrorBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="10dp"
        android:paddingLeft="7dp"
        android:paddingTop="4dp"
        android:paddingRight="7dp"
        android:paddingBottom="4dp"
        android:background="#A0B00020"
        android:text="RENDERING_ERROR"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/healthLogPanel"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_gravity="top|start"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="56dp"
        android:layout_marginRight="10dp"
        android:paddingLeft="7dp"
        android:paddingTop="5dp"
        android:paddingRight="7dp"
        android:paddingBottom="5dp"
        android:background="#66101010"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:scrollbars="vertical|horizontal"
        android:overScrollMode="always"
        android:fadeScrollbars="false"
        android:cursorVisible="false"
        android:longClickable="true"
        android:textIsSelectable="true"
        android:scrollHorizontally="true"
        android:minLines="10"
        android:text="health"
        android:textColor="#FFFFCC80"
        android:textSize="10sp"
        android:typeface="monospace"
        android:visibility="gone" />

    <TextView
        android:id="@+id/debugStepPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="12dp"
        android:paddingLeft="10dp"
        android:paddingTop="6dp"
        android:paddingRight="10dp"
        android:paddingBottom="6dp"
        android:background="#AA202020"
        android:text="TEST STEPS"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:typeface="monospace"
        android:visibility="gone" />

    <TextView
        android:id="@+id/copyLogButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="56dp"
        android:layout_marginRight="10dp"
        android:paddingLeft="8dp"
        android:paddingTop="4dp"
        android:paddingRight="8dp"
        android:paddingBottom="4dp"
        android:background="#88404040"
        android:text="COPY LOG"
        android:textColor="#FFFFFFFF"
        android:textSize="10sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/fallbackBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="8dp"
        android:paddingLeft="6dp"
        android:paddingTop="3dp"
        android:paddingRight="6dp"
        android:paddingBottom="3dp"
        android:background="#80000000"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/debugPanel"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="8dp"
        android:background="#80000000"
        android:orientation="vertical"
        android:padding="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/debugFpsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="FPS: -- fps"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp" />

        <com.proto.demo.DebugSparklineView
            android:id="@+id/debugFpsChart"
            android:layout_width="match_parent"
            android:layout_height="46dp" />

        <TextView
            android:id="@+id/debugDropLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="DROP: -- fps"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp" />

        <com.proto.demo.DebugSparklineView
            android:id="@+id/debugDropChart"
            android:layout_width="match_parent"
            android:layout_height="46dp" />

        <TextView
            android:id="@+id/debugCpuLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="CPU: -- %"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp" />

        <com.proto.demo.DebugSparklineView
            android:id="@+id/debugCpuChart"
            android:layout_width="match_parent"
            android:layout_height="46dp" />

        <TextView
            android:id="@+id/debugGpuLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="GPU: -- %"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp" />

        <com.proto.demo.DebugSparklineView
            android:id="@+id/debugGpuChart"
            android:layout_width="match_parent"
            android:layout_height="46dp" />

        <TextView
            android:id="@+id/debugRamLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="RAM: -- MB"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp" />

        <com.proto.demo.DebugSparklineView
            android:id="@+id/debugRamChart"
            android:layout_width="match_parent"
            android:layout_height="46dp" />

        <TextView
            android:id="@+id/debugNetLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="NET: UP -- Mbps | DL -- Mbps"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp" />

        <com.proto.demo.DebugSparklineView
            android:id="@+id/debugNetChart"
            android:layout_width="match_parent"
            android:layout_height="46dp" />

    </LinearLayout>
    <LinearLayout
        android:id="@+id/splashPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE080808"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="wbeam"
            android:textColor="#FFFFFFFF"
            android:textSize="42sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="preflight checks"
            android:textColor="#666666"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/splashChecks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/splashStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="checking…"
            android:textColor="#555555"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ── Diagnostic mode cycle button ─────────────────── -->
    <TextView
        android:id="@+id/diagCycleBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:paddingLeft="24dp"
        android:paddingTop="12dp"
        android:paddingRight="24dp"
        android:paddingBottom="12dp"
        android:background="#CC1A3A99"
        android:text="MODE TEST"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- ── Mode name overlay (shown during cycling) ─────── -->
    <LinearLayout
        android:id="@+id/diagModeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD010101"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/diagModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="MODE"
            android:textColor="#FFFFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/diagModeCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="10s"
            android:textColor="#AAAAAA"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/diagModeStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text=""
            android:textColor="#88FFFF88"
            android:textSize="14sp"
            android:typeface="monospace" />

    </LinearLayout>

</FrameLayout>
