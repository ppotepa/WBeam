group="${1:-}"
cmd="${2:-}"

if [[ -z "$group" ]]; then
  print_help
  exit 1
fi

case "$group" in
  ip)
    case "$cmd" in
      up)             ip_up ;;
      down)           ip_down ;;
      status)         ip_status ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  host)
    case "$cmd" in
      build)          host_build ;;
      run|start|up)   host_run ;;
      debug)          host_debug ;;
      status)         daemon_status ;;
      down|stop)      daemon_down ;;
      probe)          shift 2; host_probe "$@" ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  daemon)
    case "$cmd" in
      up|start|run)   daemon_up ;;
      down|stop)      daemon_down ;;
      status)         daemon_status ;;
      debug)          host_debug ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  android)
    case "$cmd" in
      build)          android_build ;;
      install)        android_install ;;
      launch)         android_launch ;;
      deploy|run)     android_deploy ;;
      deploy-all|run-all) android_deploy_all ;;
      build-release|release-build)    android_build_release ;;
      install-release|release-install) android_install_release ;;
      deploy-release|release-deploy)   android_deploy_release ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  x11proto)
    case "$cmd" in
      probe-host|probe) shift 2; x11proto_run probe-host "$@" ;;
      doctor|status|start|stop|smoke|acceptance) shift 2; x11proto_run "$cmd" "$@" ;;
      android-build) x11proto_android_build ;;
      android-deploy) x11proto_android_deploy ;;
      *) print_help; exit 1 ;;
    esac
    ;;
  train)
    case "$cmd" in
      wizard|tui|run) shift 2; train_wizard "$@" ;;
      *) print_help; exit 1 ;;
    esac
    ;;
  deps)
    case "$cmd" in
      virtual)
        case "${3:-}" in
          check) shift 3; deps_virtual_check "$@" ;;
          install) shift 3; deps_virtual_install "$@" ;;
          *) print_help; exit 1 ;;
        esac
        ;;
      *) print_help; exit 1 ;;
    esac
    ;;
  version)
    case "$cmd" in
      new)            version_new ;;
      current)        version_current ;;
      doctor|diag|diagnose) version_doctor ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  watch)
    case "$cmd" in
      tui)
        watch_tui_loop
        ;;
      devices|connections|streaming|service|logs|status|health|doctor)
        case "${3:-}" in
          --once|once) watch_run_loop "$cmd" "once" ;;
          *)           watch_run_loop "$cmd" "loop" ;;
        esac
        ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  debug)
    case "$cmd" in
      up|start)       debug_up ;;
      watch|logs)     debug_watch ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  logs)
    case "$cmd" in
      live)           logs_live ;;
      host)           logs_host ;;
      adb)            logs_adb "${3:-status}" ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    print_help
    exit 1
    ;;
esac
