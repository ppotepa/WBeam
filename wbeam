  fi
}

watch_devices_once() {
  require_cmd adb
  local serial api model batt apk batt_view max_res session_state stream_port idx
  local status_json
  local -a serials

  adb start-server >/dev/null 2>&1 || true
  mapfile -t serials < <(android_connected_serials)
  printf '%-14s %s\n' "adb_devices" "${#serials[@]}"
  if [[ "${#serials[@]}" -eq 0 ]]; then
    echo "no adb devices in state=device"
    return 0
  fi

  printf '%-18s %-18s %-4s %-6s %-11s %-10s %-10s %-18s\n' "serial" "model" "api" "port" "max_res" "streaming" "battery" "apk"
  printf '%-18s %-18s %-4s %-6s %-11s %-10s %-10s %-18s\n' "------" "-----" "---" "----" "-------" "---------" "-------" "---"
  idx=1
  for serial in "${serials[@]}"; do
    api="$(adb -s "$serial" shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r[:space:]' || true)"
    model="$(adb -s "$serial" shell getprop ro.product.model 2>/dev/null | tr -d '\r' || true)"
    batt="$(adb -s "$serial" shell dumpsys battery 2>/dev/null | awk -F': ' '/level:/{print $2; exit}' | tr -d '\r[:space:]' || true)"
    apk="$(adb -s "$serial" shell dumpsys package "$ANDROID_PACKAGE" 2>/dev/null | sed -n 's/^[[:space:]]*versionName=//p' | head -n1 | tr -d '\r' || true)"
    stream_port="$(watch_device_stream_port "$idx")"
    status_json="$(watch_session_status_json "$serial" "$stream_port")"
    session_state="$(json_string_field "$status_json" "state")"
    if [[ -z "$session_state" ]]; then
      session_state="unknown"
    fi
    max_res="$(watch_android_max_res "$serial")"
    batt_view="${batt:-unknown}%"
    if [[ "$batt" =~ ^[0-9]+$ ]]; then
      if (( batt < 20 )); then
        batt_view="$(watch_status_label "low:${batt}%")"
      elif (( batt < 50 )); then
        batt_view="$(watch_status_label "mid:${batt}%")"
      else
        batt_view="$(watch_status_label "high:${batt}%")"
      fi
    fi
    printf '%-18s %-18s %-4s %-6s %-11s %-10s %-10s %-18s\n' \
      "$serial" "${model:-unknown}" "${api:-unknown}" "${stream_port}" "${max_res}" "$(watch_status_label "${session_state}")" "$batt_view" "${apk:-<none>}"
    idx=$((idx + 1))
  done
}

watch_connections_once() {
  local serial
  local health_json="" probe_json="" status_json="" rev=""
  local ok service build_rev stream_alive state supported capture session remote display
  local stream_port control_port reverse_count
  local -a serials

  health_json="$(curl -fsS --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/health" 2>/dev/null || true)"
  probe_json="$(curl -fsS --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/host-probe" 2>/dev/null || true)"
  status_json="$(curl -fsS --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/status" 2>/dev/null || true)"

  echo "host:"
  if [[ -z "$health_json" || -z "$probe_json" ]]; then
    echo "  health=$(watch_status_label unreachable) probe=$(watch_status_label unreachable)"
  else
    service="$(json_string_field "$health_json" "service")"
    build_rev="$(json_string_field "$health_json" "build_revision")"
    ok="$(json_scalar_field "$health_json" "ok")"
    stream_alive="$(json_scalar_field "$health_json" "stream_process_alive")"
    supported="$(json_scalar_field "$probe_json" "supported")"
    capture="$(json_string_field "$probe_json" "capture_mode")"
    session="$(json_string_field "$probe_json" "session")"
    remote="$(json_scalar_field "$probe_json" "remote")"
    display="$(json_string_field "$probe_json" "display")"
    state="$(json_string_field "$status_json" "state")"
    stream_port="$(json_scalar_field "$status_json" "stream_port")"
    control_port="$(json_scalar_field "$status_json" "control_port")"
    printf '  %-12s %-14s %-10s %-10s\n' "service" "${service:-unknown}" "build" "${build_rev:-unknown}"
    printf '  %-12s %-14s %-10s %-10s\n' "state" "${state:-unknown}" "capture" "${capture:-unknown}"
    printf '  %-12s %-14s %-10s %-10s\n' "ok" "$(watch_status_label "${ok:-unknown}")" "supported" "$(watch_status_label "${supported:-unknown}")"
    printf '  %-12s %-14s %-10s %-10s\n' "stream_proc" "$(watch_status_label "${stream_alive:-unknown}")" "remote" "$(watch_status_label "${remote:-unknown}")"
    printf '  %-12s %-14s %-10s %-10s\n' "session" "${session:-unknown}" "display" "${display:-unknown}"
    printf '  %-12s %-14s\n' "ports" "${control_port:-?}/${stream_port:-?}"
  fi
  echo

  echo "adb reverse:"
  if command -v adb >/dev/null 2>&1; then
    mapfile -t serials < <(android_connected_serials)
    if [[ "${#serials[@]}" -eq 0 ]]; then
      echo "  devices=$(watch_status_label none)"
      return 0
    fi
    printf '  %-18s %-14s\n' "serial" "reverse"
    printf '  %-18s %-14s\n' "------" "-------"
    for serial in "${serials[@]}"; do
      rev="$(adb -s "$serial" reverse --list 2>/dev/null || true)"
      if [[ -z "$rev" ]]; then
        printf '  %-18s %-14s\n' "$serial" "$(watch_status_label unavailable)"
      else
        reverse_count="$(printf '%s\n' "$rev" | sed '/^[[:space:]]*$/d' | wc -l | tr -d '[:space:]')"
        printf '  %-18s %-14s\n' "$serial" "$(watch_status_label "$reverse_count")"
      fi
    done
  fi
}

