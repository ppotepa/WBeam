    return 0
  fi
  if [[ -d "/usr/lib/jvm/java-17-openjdk" ]]; then
    echo "/usr/lib/jvm/java-17-openjdk"
    return 0
  fi
  return 1
}

android_gradle_build_retry_once() {
  local task="$1"
  local min_sdk="$2"
  local build_api_host="$3"
  local build_stream_host="$4"
  local build_control_port="$5"
  local build_stream_port="$6"
  local gradle_user_home="$7"
  local build_version="$8"
  local gradle_java_home=""
  local -a gradle_env
  local tmp_log
  local extra_args=()
  tmp_log="$(mktemp "$ROOT_DIR/.gradle-build.XXXXXX.log")"
  gradle_java_home="$(android_select_java_home || true)"
  gradle_env=(GRADLE_USER_HOME="$gradle_user_home")
  if [[ -n "$gradle_java_home" ]]; then
    gradle_env+=(JAVA_HOME="$gradle_java_home")
  fi

  if [[ "$task" == ":app:assembleRelease" ]]; then
    # Local deploy path: don't block release build on lint-vital crashes/noise.
    extra_args=(-x :app:lintVitalAnalyzeRelease -x :app:lintVitalReportRelease -x :app:lintVitalRelease)
  fi

  if [[ -n "$gradle_java_home" ]]; then
    echo "[android] Using JAVA_HOME=${gradle_java_home} for Gradle" >&2
  fi

  if (cd "$ANDROID_DIR" && env "${gradle_env[@]}" bash ./gradlew --no-daemon \
      -PWBEAM_MIN_SDK="$min_sdk" \
      -PWBEAM_BUILD_REV="$build_version" \
      -PWBEAM_HOST="$build_stream_host" \
      -PWBEAM_API_HOST="$build_api_host" \
      -PWBEAM_STREAM_HOST="$build_stream_host" \
      -PWBEAM_CONTROL_PORT="$build_control_port" \
      -PWBEAM_STREAM_PORT="$build_stream_port" \
      -PWBEAM_ANDROID_SERIAL="${ANDROID_SERIAL:-}" \
      "${extra_args[@]}" "$task" 2>&1 | tee "$tmp_log"); then
    rm -f "$tmp_log"
    return 0
  fi

  if grep -q "Could not read workspace metadata" "$tmp_log"; then
    echo "[android] WARN: detected Gradle workspace metadata corruption; retrying once after cache rotation..." >&2
    android_rotate_gradle_workspace_cache "$gradle_user_home"
    rm -f "$tmp_log"
    cd "$ANDROID_DIR" && env "${gradle_env[@]}" bash ./gradlew --no-daemon \
      -PWBEAM_MIN_SDK="$min_sdk" \
      -PWBEAM_BUILD_REV="$build_version" \
      -PWBEAM_HOST="$build_stream_host" \
      -PWBEAM_API_HOST="$build_api_host" \
      -PWBEAM_STREAM_HOST="$build_stream_host" \
      -PWBEAM_CONTROL_PORT="$build_control_port" \
      -PWBEAM_STREAM_PORT="$build_stream_port" \
      -PWBEAM_ANDROID_SERIAL="${ANDROID_SERIAL:-}" \
      "${extra_args[@]}" "$task"
    return $?
  fi

  rm -f "$tmp_log"
  return 1
}

android_install_release() {
  local release_apk=""
  if [[ -f "$ANDROID_APK_RELEASE" ]]; then
    release_apk="$ANDROID_APK_RELEASE"
  elif [[ -f "$ANDROID_APK_RELEASE_UNSIGNED" ]]; then
    release_apk="$ANDROID_APK_RELEASE_UNSIGNED"
  fi

  if [[ -z "$release_apk" ]]; then
    echo "Release APK not found." >&2
    echo "Run './wbeam android build-release' first." >&2
    exit 1
  fi

  if [[ "$release_apk" == *"-unsigned.apk" ]]; then
    echo "Release APK is unsigned: $release_apk" >&2
    echo "Configure signing for release build before install, or use debug deploy for local testing." >&2
    exit 1
  fi

  adb start-server >/dev/null
  adb_device_cmd wait-for-device
  if android_should_skip_install "$release_apk"; then
    echo "[android] APK version+config unchanged ($(android_expected_version_name)); skipping release install (${ANDROID_SERIAL:-default})."
    return 0
  fi
  echo "[android] Installing $release_apk ($(android_target_desc))…"
  android_install_with_signature_recover "$release_apk" "$ANDROID_PACKAGE"
  local build_stamp install_stamp
  build_stamp="$(android_build_stamp_path "$release_apk")"
  install_stamp="$(android_install_stamp_path "$release_apk")"
  if [[ -f "$build_stamp" ]]; then
    cp "$build_stamp" "$install_stamp" 2>/dev/null || true
  fi
}

android_deploy_release() {
  local pipeline_mode build_hosts build_api_host build_stream_host
  adb_logcat_ensure_running
  pipeline_mode="$(android_pipeline_mode)"
  build_hosts="$(android_resolve_deploy_hosts "$pipeline_mode")"
  build_api_host="${build_hosts%%|*}"
  build_stream_host="${build_hosts##*|}"
  echo "[android] Release deploy hosts: api=$build_api_host stream=$build_stream_host"
  WBEAM_ANDROID_API_HOST="$build_api_host" WBEAM_ANDROID_STREAM_HOST="$build_stream_host" android_build_release
  android_install_release
  android_launch
}

