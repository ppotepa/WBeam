watch_use_color() {
  if [[ "${WBEAM_WATCH_COLOR:-0}" == "1" ]]; then
    return 0
  fi
  [[ -t 1 && "${NO_COLOR:-0}" != "1" ]]
}

watch_style() {
  local name="$1"
  if watch_use_color; then
    case "$name" in
      reset) printf '\033[0m' ;;
      title) printf '\033[1;36m' ;;
      ok)    printf '\033[1;32m' ;;
      warn)  printf '\033[1;33m' ;;
      err)   printf '\033[1;31m' ;;
      dim)   printf '\033[2m' ;;
      *)     printf '' ;;
    esac
  fi
}

watch_status_label() {
  local value="$1"
  case "$value" in
    true|ok|match|reachable|running)
      printf '%s%s%s' "$(watch_style ok)" "$value" "$(watch_style reset)"
      ;;
    2??)
      printf '%s%s%s' "$(watch_style ok)" "$value" "$(watch_style reset)"
      ;;
    false|mismatch|unreachable|stopped|none|missing)
      printf '%s%s%s' "$(watch_style err)" "$value" "$(watch_style reset)"
      ;;
    4??|5??|000|unavailable)
      printf '%s%s%s' "$(watch_style err)" "$value" "$(watch_style reset)"
      ;;
    *)
      printf '%s%s%s' "$(watch_style warn)" "$value" "$(watch_style reset)"
      ;;
  esac
}

watch_print_header() {
  local topic="$1"
  printf '%s[watch:%s]%s %s\n' "$(watch_style title)" "$topic" "$(watch_style reset)" "$(date -Iseconds)"
  printf '%s[watch:%s]%s host=%s control_port=%s stream_port=%s\n' \
    "$(watch_style dim)" "$topic" "$(watch_style reset)" \
    "$(hostname 2>/dev/null || echo unknown)" "$CONTROL_PORT" "$STREAM_PORT"
}

watch_device_stream_port() {
  local idx="$1"
  echo $((STREAM_PORT + idx))
}

watch_android_max_res() {
  local serial="$1"
  local res=""
  res="$(adb -s "$serial" shell wm size 2>/dev/null | sed -n 's/.*Physical size:[[:space:]]*//p' | head -n1 | tr -d '\r' || true)"
  if [[ -n "$res" ]]; then
    echo "$res"
    return 0
  fi

  local w h
  w="$(adb -s "$serial" shell dumpsys display 2>/dev/null | sed -n 's/.*deviceWidth=\([0-9][0-9]*\).*/\1/p' | head -n1 | tr -d '\r' || true)"
  h="$(adb -s "$serial" shell dumpsys display 2>/dev/null | sed -n 's/.*deviceHeight=\([0-9][0-9]*\).*/\1/p' | head -n1 | tr -d '\r' || true)"
  if [[ -n "$w" && -n "$h" ]]; then
    echo "${w}x${h}"
    return 0
  fi
  echo "unknown"
}

