#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST_SCRIPTS_DIR="$ROOT_DIR/host/scripts"

CONTROL_PORT="${WBEAM_CONTROL_PORT:-5001}"
STREAM_PORT="${WBEAM_STREAM_PORT:-5000}"

SERVICE_NAME="wbeam-daemon"
SERVICE_FILE="$HOME/.config/systemd/user/${SERVICE_NAME}.service"
DAEMON_BIN="$ROOT_DIR/host/rust/target/release/wbeamd-server"

ANDROID_DIR="$ROOT_DIR/android"
ANDROID_PACKAGE="com.wbeam"
ANDROID_ACTIVITY=".MainActivity"
ANDROID_APK="$ANDROID_DIR/app/build/outputs/apk/debug/app-debug.apk"
ANDROID_APK_RELEASE="$ANDROID_DIR/app/build/outputs/apk/release/app-release.apk"
ANDROID_APK_RELEASE_UNSIGNED="$ANDROID_DIR/app/build/outputs/apk/release/app-release-unsigned.apk"
ANDROID_SERIAL="${WBEAM_ANDROID_SERIAL:-}"
ANDROID_PIPELINE_FILE="$ROOT_DIR/.wbeam_android_pipeline"



print_help() {
  cat <<'EOF'
WBeam command runner

Usage:
  ./wbeam <group> <command>
  ./wbgui                        # interactive TUI menu (arrow keys)

Groups:
  service   up | down | restart | status | remove | logs
  ip        up | down | status
  host      run | debug | status | down
  daemon    up | down | status   (alias for host)
  android   build | install | launch | deploy | build-release | install-release | deploy-release
  debug     up | watch           (alias for host debug)
  logs      live | daemon | host

Examples:
  ./wbgui
  ./wbeam host run               # release binary, foreground
  ./wbeam host debug             # debug build + coloured logs + ADB sidecar
  ./wbeam android deploy         # build + install + launch in one step
  ./wbeam android build          # ./gradlew assembleDebug only
  ./wbeam android install        # adb install only (uses existing debug APK)
  ./wbeam android launch         # adb shell am start only
  ./wbeam android build-release  # ./gradlew assembleRelease
  ./wbeam android install-release
  ./wbeam android deploy-release
  ./wbeam debug up
  ./wbeam logs live
EOF
}

adb_device_cmd() {
  require_cmd adb
  if [[ -n "$ANDROID_SERIAL" ]]; then
    adb -s "$ANDROID_SERIAL" "$@"
  else
    adb "$@"
  fi
}

android_pipeline_mode() {
  local mode="${WBEAM_ANDROID_PIPELINE:-}"
  if [[ -z "$mode" && -f "$ANDROID_PIPELINE_FILE" ]]; then
    mode="$(tr -d '[:space:]' < "$ANDROID_PIPELINE_FILE" 2>/dev/null || true)"
  fi

  case "$mode" in
    legacy|modern)
      echo "$mode"
      ;;
    *)
      echo "modern"
      ;;
  esac
}

android_pipeline_min_sdk() {
  case "$1" in
    legacy) echo "17" ;;
    *) echo "19" ;;
  esac
}

detect_host_ip() {
  local ip_candidate=""
  ip_candidate="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++){if($i=="src"){print $(i+1); exit}}}')"
  if [[ -n "$ip_candidate" ]]; then
    echo "$ip_candidate"
    return 0
  fi
  ip_candidate="$(hostname -I 2>/dev/null | awk '{print $1}')"
  if [[ -n "$ip_candidate" ]]; then
    echo "$ip_candidate"
    return 0
  fi
  return 1
}

android_build_host() {
  local pipeline_mode="$1"
  if [[ -n "${WBEAM_ANDROID_HOST:-}" ]]; then
    echo "$WBEAM_ANDROID_HOST"
    return 0
  fi

  if [[ "$pipeline_mode" == "legacy" ]]; then
    local detected
    detected="$(detect_host_ip || true)"
    if [[ -n "$detected" ]]; then
      echo "$detected"
      return 0
    fi
  fi

  echo "127.0.0.1"
}

android_device_has_ipv4() {
  local ips line ip
  ips="$(adb_device_cmd shell "ip addr 2>/dev/null | grep 'inet ' | sed -E 's/.*inet ([0-9.]+).*/\\1/'" 2>/dev/null | tr -d '\r')"
  while IFS= read -r line; do
    ip="${line%%/*}"
    if [[ -n "$ip" && "$ip" != "127.0.0.1" ]]; then
      return 0
    fi
  done <<< "$ips"
  return 1
}

android_try_reverse_setup() {
  adb_device_cmd reverse "tcp:${STREAM_PORT}" "tcp:${STREAM_PORT}" >/dev/null 2>&1 || return 1
  adb_device_cmd reverse "tcp:${CONTROL_PORT}" "tcp:${CONTROL_PORT}" >/dev/null 2>&1 || return 1
  return 0
}

android_echo_hosts() {
  local api_host="$1"
  local stream_host="$2"
  printf '%s|%s\n' "$api_host" "$stream_host"
}

android_resolve_deploy_hosts() {
  local pipeline_mode="$1"
  local allow_no_transport="${WBEAM_ANDROID_ALLOW_NO_TRANSPORT:-0}"
  local api_only_fallback="${WBEAM_ANDROID_API_ONLY_FALLBACK:-0}"

  if [[ -n "${WBEAM_ANDROID_API_HOST:-}" || -n "${WBEAM_ANDROID_STREAM_HOST:-}" || -n "${WBEAM_ANDROID_HOST:-}" ]]; then
    local explicit_api="${WBEAM_ANDROID_API_HOST:-${WBEAM_ANDROID_HOST:-127.0.0.1}}"
    local explicit_stream="${WBEAM_ANDROID_STREAM_HOST:-${WBEAM_ANDROID_HOST:-127.0.0.1}}"
    android_echo_hosts "$explicit_api" "$explicit_stream"
    return 0
  fi

  if [[ "$pipeline_mode" != "legacy" ]]; then
    android_echo_hosts "127.0.0.1" "127.0.0.1"
    return 0
  fi

  require_cmd adb
  adb start-server >/dev/null
  adb_device_cmd wait-for-device

  if android_try_reverse_setup; then
    android_echo_hosts "127.0.0.1" "127.0.0.1"
    return 0
  fi

  local host_ip
  host_ip="$(detect_host_ip || true)"

  if android_device_has_ipv4 && [[ -n "$host_ip" ]]; then
    if [[ "$api_only_fallback" =~ ^(1|true|TRUE|yes|on)$ ]]; then
      android_echo_hosts "$host_ip" "127.0.0.1"
    else
      android_echo_hosts "$host_ip" "$host_ip"
    fi
    return 0
  fi

  if [[ "$allow_no_transport" =~ ^(1|true|TRUE|yes|on)$ ]]; then
    echo "[android] WARN: no active reverse/LAN path detected; forcing loopback host 127.0.0.1 for deploy." >&2
    echo "[android] WARN: app may stay offline until adb reverse starts working on this device." >&2
    android_echo_hosts "127.0.0.1" "127.0.0.1"
    return 0
  fi

  echo "[android] ERROR: no transport path to host for legacy device." >&2
  echo "[android] - adb reverse is unavailable on this device (or ADB transport is unstable)." >&2
  echo "[android] - device has no active IPv4 network interface for LAN fallback." >&2
  echo "[android] Hint: set WBEAM_ANDROID_ALLOW_NO_TRANSPORT=1 to force loopback deploy despite missing tunnel." >&2
  echo "[android] Fix: connect tablet to Wi-Fi (same LAN as host) or set WBEAM_ANDROID_HOST manually after network is up." >&2
  return 1
}

android_target_desc() {
  if [[ -n "$ANDROID_SERIAL" ]]; then
    echo "serial=$ANDROID_SERIAL"
  else
    echo "default-device"
  fi
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

ensure_daemon_binary() {
  if [[ -x "$DAEMON_BIN" ]]; then
    return 0
  fi
  echo "Daemon binary missing: $DAEMON_BIN" >&2
  echo "Build it first:" >&2
  echo "  cd $ROOT_DIR/host/rust && cargo build --release -p wbeamd-server -p wbeamd-streamer" >&2
  exit 1
}

stop_local_processes() {
  pkill -9 wbeamd-streamer 2>/dev/null || true
  pkill -9 wbeamd-server 2>/dev/null || true
  rm -f /tmp/wbeamd.lock
}

service_write_unit() {
  mkdir -p "$HOME/.config/systemd/user"
  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=WBeam Screen Streaming Daemon
After=graphical-session.target

[Service]
Type=simple
ExecStart=$DAEMON_BIN --control-port $CONTROL_PORT --stream-port $STREAM_PORT --root $ROOT_DIR
Restart=on-failure
RestartSec=5
Environment="RUST_LOG=info"
Environment="WBEAM_USE_RUST_STREAMER=1"
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
EOF
}

service_up() {
  require_cmd systemctl
  ensure_daemon_binary
  stop_local_processes

  if [[ ! -f "$SERVICE_FILE" ]]; then
    service_write_unit
  fi

  systemctl --user daemon-reload
  systemctl --user enable "$SERVICE_NAME" >/dev/null 2>&1 || true
  systemctl --user restart "$SERVICE_NAME"
  sleep 1
  service_status
}

service_down() {
  require_cmd systemctl
  systemctl --user stop "$SERVICE_NAME" >/dev/null 2>&1 || true
  stop_local_processes
  echo "Service stopped."
}

service_restart() {
  service_down
  service_up
}

service_remove() {
  require_cmd systemctl
  systemctl --user stop "$SERVICE_NAME" >/dev/null 2>&1 || true
  systemctl --user disable "$SERVICE_NAME" >/dev/null 2>&1 || true
  rm -f "$SERVICE_FILE"
  systemctl --user daemon-reload
  stop_local_processes
  echo "Service removed: $SERVICE_FILE"
}

service_status() {
  if command -v systemctl >/dev/null 2>&1; then
    if [[ -f "$SERVICE_FILE" ]]; then
      systemctl --user status "$SERVICE_NAME" --no-pager --full || true
    else
      echo "Service file not installed: $SERVICE_FILE"
    fi
  fi
  echo
  if curl -sSf "http://127.0.0.1:${CONTROL_PORT}/status" >/dev/null 2>&1; then
    curl -sS "http://127.0.0.1:${CONTROL_PORT}/status"
    echo
  else
    echo "Control API not reachable on 127.0.0.1:${CONTROL_PORT}"
  fi
}

service_logs() {
  require_cmd journalctl
  journalctl --user -u "$SERVICE_NAME" -f
}

ip_up() {
  require_cmd adb
  adb start-server >/dev/null
  adb_device_cmd wait-for-device
  adb_device_cmd reverse "tcp:${STREAM_PORT}" "tcp:${STREAM_PORT}"
  adb_device_cmd reverse "tcp:${CONTROL_PORT}" "tcp:${CONTROL_PORT}"
  ip_status
}

ip_down() {
  adb_device_cmd reverse --remove "tcp:${STREAM_PORT}" >/dev/null 2>&1 || true
  adb_device_cmd reverse --remove "tcp:${CONTROL_PORT}" >/dev/null 2>&1 || true
  ip_status
}

ip_status() {
  adb_device_cmd version >/dev/null
  echo "ADB reverse mappings:"
  adb_device_cmd reverse --list || true
}

# Run the release binary in the foreground (no systemd, clean output)
host_run() {
  ensure_daemon_binary
  stop_local_processes
  if command -v adb >/dev/null 2>&1; then
    adb start-server >/dev/null 2>&1 || true
    adb reverse "tcp:${STREAM_PORT}"   "tcp:${STREAM_PORT}"   2>/dev/null || true
    adb reverse "tcp:${CONTROL_PORT}" "tcp:${CONTROL_PORT}" 2>/dev/null || true
  fi
  echo "[wbeam] host run — release binary, foreground"
  echo "[wbeam] control=127.0.0.1:${CONTROL_PORT}  stream=127.0.0.1:${STREAM_PORT}"
  echo "[wbeam] Ctrl-C to stop"
  echo ""
  export RUST_LOG="${RUST_LOG:-info}"
  export WBEAM_USE_RUST_STREAMER=1
  exec "$DAEMON_BIN" \
    --control-port "$CONTROL_PORT" \
    --stream-port  "$STREAM_PORT" \
    --root         "$ROOT_DIR"
}

# Debug run: full RUST_LOG=debug, coloured output, ADB logcat sidecar
host_debug() {
  exec "$HOST_SCRIPTS_DIR/run_wbeamd_debug.sh" "$CONTROL_PORT" "$STREAM_PORT"
}

# Backwards-compat aliases
daemon_up()   { host_run; }
daemon_down() { stop_local_processes; echo "Daemon processes stopped."; }
daemon_status() {
  if curl -sSf "http://127.0.0.1:${CONTROL_PORT}/status" >/dev/null 2>&1; then
    curl -sS "http://127.0.0.1:${CONTROL_PORT}/status"
    echo
  else
    echo "Control API not reachable on 127.0.0.1:${CONTROL_PORT}"
    exit 1
  fi
}

android_build() {
  local pipeline_mode min_sdk build_api_host build_stream_host
  pipeline_mode="$(android_pipeline_mode)"
  min_sdk="$(android_pipeline_min_sdk "$pipeline_mode")"
  build_api_host="${WBEAM_ANDROID_API_HOST:-${WBEAM_ANDROID_HOST:-$(android_build_host "$pipeline_mode")}}"
  build_stream_host="${WBEAM_ANDROID_STREAM_HOST:-${WBEAM_ANDROID_HOST:-$(android_build_host "$pipeline_mode")}}"

  echo "[android] Building debug APK (pipeline=${pipeline_mode}, minSdk=${min_sdk}, api_host=${build_api_host}, stream_host=${build_stream_host})…"
  cd "$ANDROID_DIR" && ./gradlew -PWBEAM_MIN_SDK="$min_sdk" -PWBEAM_HOST="$build_stream_host" -PWBEAM_API_HOST="$build_api_host" -PWBEAM_STREAM_HOST="$build_stream_host" :app:assembleDebug
  echo "[android] APK: $ANDROID_APK"
}

android_install() {
  if [[ ! -f "$ANDROID_APK" ]]; then
    echo "APK not found: $ANDROID_APK" >&2
    echo "Run './wbeam android build' first." >&2
    exit 1
  fi
  adb start-server >/dev/null
  adb_device_cmd wait-for-device
  echo "[android] Installing $ANDROID_APK (${ANDROID_SERIAL:-default})…"
  adb_device_cmd install -r "$ANDROID_APK"
}

android_launch() {
  adb start-server >/dev/null
  adb_device_cmd wait-for-device
  echo "[android] Launching ${ANDROID_PACKAGE}/${ANDROID_ACTIVITY} ($(android_target_desc))…"
  adb_device_cmd shell am start -n "${ANDROID_PACKAGE}/${ANDROID_ACTIVITY}"
}

android_deploy() {
  local pipeline_mode build_hosts build_api_host build_stream_host
  pipeline_mode="$(android_pipeline_mode)"
  build_hosts="$(android_resolve_deploy_hosts "$pipeline_mode")"
  build_api_host="${build_hosts%%|*}"
  build_stream_host="${build_hosts##*|}"
  echo "[android] Deploy hosts: api=$build_api_host stream=$build_stream_host"
  WBEAM_ANDROID_API_HOST="$build_api_host" WBEAM_ANDROID_STREAM_HOST="$build_stream_host" android_build
  android_install
  android_launch
}

android_build_release() {
  local pipeline_mode min_sdk build_api_host build_stream_host
  pipeline_mode="$(android_pipeline_mode)"
  min_sdk="$(android_pipeline_min_sdk "$pipeline_mode")"
  build_api_host="${WBEAM_ANDROID_API_HOST:-${WBEAM_ANDROID_HOST:-$(android_build_host "$pipeline_mode")}}"
  build_stream_host="${WBEAM_ANDROID_STREAM_HOST:-${WBEAM_ANDROID_HOST:-$(android_build_host "$pipeline_mode")}}"

  echo "[android] Building release APK (pipeline=${pipeline_mode}, minSdk=${min_sdk}, api_host=${build_api_host}, stream_host=${build_stream_host})…"
  cd "$ANDROID_DIR" && ./gradlew -PWBEAM_MIN_SDK="$min_sdk" -PWBEAM_HOST="$build_stream_host" -PWBEAM_API_HOST="$build_api_host" -PWBEAM_STREAM_HOST="$build_stream_host" :app:assembleRelease
  if [[ -f "$ANDROID_APK_RELEASE" ]]; then
    echo "[android] APK: $ANDROID_APK_RELEASE"
  elif [[ -f "$ANDROID_APK_RELEASE_UNSIGNED" ]]; then
    echo "[android] APK: $ANDROID_APK_RELEASE_UNSIGNED"
  fi
}

android_install_release() {
  local release_apk=""
  if [[ -f "$ANDROID_APK_RELEASE" ]]; then
    release_apk="$ANDROID_APK_RELEASE"
  elif [[ -f "$ANDROID_APK_RELEASE_UNSIGNED" ]]; then
    release_apk="$ANDROID_APK_RELEASE_UNSIGNED"
  fi

  if [[ -z "$release_apk" ]]; then
    echo "Release APK not found." >&2
    echo "Run './wbeam android build-release' first." >&2
    exit 1
  fi

  if [[ "$release_apk" == *"-unsigned.apk" ]]; then
    echo "Release APK is unsigned: $release_apk" >&2
    echo "Configure signing for release build before install, or use debug deploy for local testing." >&2
    exit 1
  fi

  adb start-server >/dev/null
  adb_device_cmd wait-for-device
  echo "[android] Installing $release_apk ($(android_target_desc))…"
  adb_device_cmd install -r "$release_apk"
}

android_deploy_release() {
  local pipeline_mode build_hosts build_api_host build_stream_host
  pipeline_mode="$(android_pipeline_mode)"
  build_hosts="$(android_resolve_deploy_hosts "$pipeline_mode")"
  build_api_host="${build_hosts%%|*}"
  build_stream_host="${build_hosts##*|}"
  echo "[android] Release deploy hosts: api=$build_api_host stream=$build_stream_host"
  WBEAM_ANDROID_API_HOST="$build_api_host" WBEAM_ANDROID_STREAM_HOST="$build_stream_host" android_build_release
  android_install_release
  android_launch
}

debug_up() {
  exec "$HOST_SCRIPTS_DIR/run_wbeamd_debug.sh" "$CONTROL_PORT" "$STREAM_PORT"
}

debug_watch() {
  exec "$HOST_SCRIPTS_DIR/watch_live_debug_logs.sh"
}

logs_live() {
  debug_watch
}

logs_daemon() {
  service_logs
}

logs_host() {
  local host_log
  host_log="$(ls -1t "$ROOT_DIR"/host/rust/logs/wbeamd-debug-*.log 2>/dev/null | head -n 1 || true)"
  if [[ -z "$host_log" ]]; then
    echo "No host debug log found in $ROOT_DIR/host/rust/logs"
    exit 1
  fi
  tail -n 200 -f "$host_log"
}

group="${1:-}"
cmd="${2:-}"

if [[ -z "$group" ]]; then
  print_help
  exit 1
fi

case "$group" in
  service)
    case "$cmd" in
      up|start)       service_up ;;
      down|stop)      service_down ;;
      restart)        service_restart ;;
      status)         service_status ;;
      remove|rm)      service_remove ;;
      logs)           service_logs ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  ip)
    case "$cmd" in
      up)             ip_up ;;
      down)           ip_down ;;
      status)         ip_status ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  host)
    case "$cmd" in
      run|start|up)   host_run ;;
      debug)          host_debug ;;
      status)         daemon_status ;;
      down|stop)      daemon_down ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  daemon)
    case "$cmd" in
      up|start|run)   daemon_up ;;
      down|stop)      daemon_down ;;
      status)         daemon_status ;;
      debug)          host_debug ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  android)
    case "$cmd" in
      build)          android_build ;;
      install)        android_install ;;
      launch)         android_launch ;;
      deploy|run)     android_deploy ;;
      build-release|release-build)    android_build_release ;;
      install-release|release-install) android_install_release ;;
      deploy-release|release-deploy)   android_deploy_release ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  debug)
    case "$cmd" in
      up|start)       debug_up ;;
      watch|logs)     debug_watch ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  logs)
    case "$cmd" in
      live)           logs_live ;;
      daemon)         logs_daemon ;;
      host)           logs_host ;;
      *)              print_help; exit 1 ;;
    esac
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    print_help
    exit 1
    ;;
esac
