watch_service_once() {
  local unit_path="$HOME/.config/systemd/user/${DAEMON_NAME}.service"
  local installed="false" active="unknown" enabled="unknown" sub_state="unknown"
  local main_pid="-" uptime="-"
  local health_json="" probe_json="" status_json=""
  local build_rev service_name ok stream_proc supported capture session remote display state
  local serial stream_port s_state
  local -a serials

  if [[ -f "$unit_path" ]]; then
    installed="true"
  fi

  if command -v systemctl >/dev/null 2>&1; then
    active="$(systemctl --user is-active "$DAEMON_NAME" 2>/dev/null | tr -d '\r[:space:]' || true)"
    enabled="$(systemctl --user is-enabled "$DAEMON_NAME" 2>/dev/null | tr -d '\r[:space:]' || true)"
    sub_state="$(systemctl --user show "$DAEMON_NAME" -p SubState --value 2>/dev/null | tr -d '\r[:space:]' || true)"
    main_pid="$(systemctl --user show "$DAEMON_NAME" -p MainPID --value 2>/dev/null | tr -d '\r[:space:]' || true)"
  else
    active="systemctl-missing"
    enabled="systemctl-missing"
    sub_state="systemctl-missing"
    main_pid="-"
  fi
  uptime="$(watch_service_uptime "$main_pid")"

  health_json="$(curl -fsS --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/health" 2>/dev/null || true)"
  probe_json="$(curl -fsS --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/host-probe" 2>/dev/null || true)"
  status_json="$(curl -fsS --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/status" 2>/dev/null || true)"

  echo "service:"
  printf '  %-12s %-16s %-10s %-14s\n' "installed" "$(watch_status_label "$installed")" "active" "$(watch_status_label "${active:-unknown}")"
  printf '  %-12s %-16s %-10s %-14s\n' "enabled" "$(watch_status_label "${enabled:-unknown}")" "substate" "${sub_state:-unknown}"
  printf '  %-12s %-16s %-10s %-14s\n' "main_pid" "${main_pid:-?}" "uptime" "${uptime:--}"
  echo

  echo "runtime:"
  if [[ -z "$health_json" ]]; then
    echo "  health=$(watch_status_label unreachable)"
  else
    build_rev="$(json_string_field "$health_json" "build_revision")"
    service_name="$(json_string_field "$health_json" "service")"
    ok="$(json_scalar_field "$health_json" "ok")"
    stream_proc="$(json_scalar_field "$health_json" "stream_process_alive")"
    printf '  %-12s %-16s %-10s %-14s\n' "service" "${service_name:-unknown}" "build" "${build_rev:-unknown}"
    printf '  %-12s %-16s %-10s %-14s\n' "ok" "$(watch_status_label "${ok:-unknown}")" "stream_proc" "$(watch_status_label "${stream_proc:-unknown}")"
  fi

  if [[ -n "$probe_json" ]]; then
    supported="$(json_scalar_field "$probe_json" "supported")"
    capture="$(json_string_field "$probe_json" "capture_mode")"
    session="$(json_string_field "$probe_json" "session")"
    remote="$(json_scalar_field "$probe_json" "remote")"
    display="$(json_string_field "$probe_json" "display")"
    printf '  %-12s %-16s %-10s %-14s\n' "supported" "$(watch_status_label "${supported:-unknown}")" "capture" "${capture:-unknown}"
    printf '  %-12s %-16s %-10s %-14s\n' "session" "${session:-unknown}" "remote" "$(watch_status_label "${remote:-unknown}")"
    printf '  %-12s %-16s\n' "display" "${display:-unknown}"
  else
    echo "  probe=$(watch_status_label unreachable)"
  fi
  echo

  state="$(json_string_field "$status_json" "state")"
  printf 'activity: state=%s\n' "$(watch_status_label "${state:-unknown}")"
  mapfile -t serials < <(android_connected_serials)
  if [[ "${#serials[@]}" -eq 0 ]]; then
    echo "  adb_devices=$(watch_status_label none)"
    return 0
  fi
  printf '  %-18s %-6s %-12s\n' "serial" "port" "state"
  printf '  %-18s %-6s %-12s\n' "------" "----" "-----"
  local idx=1
  for serial in "${serials[@]}"; do
    stream_port="$(watch_device_stream_port "$idx")"
    s_state="$(json_string_field "$(watch_session_status_json "$serial" "$stream_port")" "state")"
    printf '  %-18s %-6s %-12s\n' "$serial" "$stream_port" "$(watch_status_label "${s_state:-unknown}")"
    idx=$((idx + 1))
  done
}

watch_logs_latest() {
  local pattern="$1"
  ls -1t "$LOG_DIR"/$pattern 2>/dev/null | head -n 1 || true
}

watch_logs_extract_run_id() {
  local path="$1"
  basename "$path" | sed -n 's/.*\.\([0-9][0-9][0-9][0-9]\)\.log$/\1/p' | head -n 1
}

watch_logs_latest_run_id() {
  local latest
  latest="$(ls -1t "$LOG_DIR"/*.[0-9][0-9][0-9][0-9].log 2>/dev/null | head -n 1 || true)"
  if [[ -z "$latest" ]]; then
    return 1
  fi
  watch_logs_extract_run_id "$latest"
}

watch_logs_files_for_run() {
  local run_id="$1"
  ls -1t "$LOG_DIR"/*."$run_id".log 2>/dev/null || true
}

watch_logs_domain_from_file() {
  local file="$1"
  basename "$file" | sed -n 's/^[^.]*\.\(.*\)\.[0-9][0-9][0-9][0-9]\.log$/\1/p' | head -n 1
}

watch_logs_file_epoch() {
  local file="$1" stamp
  stamp="$(basename "$file" | cut -d'.' -f1)"
  date -d "${stamp:0:8} ${stamp:9:2}:${stamp:11:2}:${stamp:13:2}" +%s 2>/dev/null || echo 0
}

watch_logs_latest_per_domain() {
  local -a candidates
  local -A seen=()
  local file domain
  mapfile -t candidates < <(ls -1t "$LOG_DIR"/*.[0-9][0-9][0-9][0-9].log 2>/dev/null || true)
  for file in "${candidates[@]}"; do
    domain="$(watch_logs_domain_from_file "$file")"
    if [[ -z "$domain" ]]; then
      continue
    fi
    if [[ -z "${seen[$domain]+x}" ]]; then
      seen[$domain]="$file"
      echo "$file"
    fi
  done
}

watch_logs_once() {
  local service_lines run_id
  local -a run_files
  local -a filtered_files
  local -A seen_domain=()

  run_id="$(watch_logs_latest_run_id || true)"
  if [[ -n "$run_id" ]]; then
    mapfile -t run_files < <(watch_logs_files_for_run "$run_id")
    filtered_files=()
    seen_domain=()
    if [[ "${#run_files[@]}" -gt 0 ]]; then
      local f d
      for f in "${run_files[@]}"; do
        d="$(watch_logs_domain_from_file "$f")"
        [[ -n "$d" ]] || continue
        if [[ -z "${seen_domain[$d]+x}" ]]; then
          seen_domain[$d]=1
          filtered_files+=("$f")
        fi
      done
      run_files=("${filtered_files[@]}")
    fi
    echo "run_id: $run_id"
    if [[ "${#run_files[@]}" -gt 1 ]]; then
      local min_ts=0 max_ts=0 ts
      for f in "${run_files[@]}"; do
        ts="$(watch_logs_file_epoch "$f")"
        if [[ "$ts" =~ ^[0-9]+$ ]] && [[ "$ts" -gt 0 ]]; then
          if (( min_ts == 0 || ts < min_ts )); then min_ts="$ts"; fi
          if (( ts > max_ts )); then max_ts="$ts"; fi
        fi
      done
      if (( min_ts > 0 && max_ts > 0 && (max_ts - min_ts) > 600 )); then
        mapfile -t run_files < <(watch_logs_latest_per_domain)
        if [[ "${#run_files[@]}" -gt 0 ]]; then
          echo "mode: latest-per-domain (run-id window too wide)"
        fi
      fi
    fi
    if [[ "${#run_files[@]}" -le 1 ]]; then
      # Some workflows allocate run counters per-domain; show latest file for each
      # domain so diagnostics include host/adb/desktop/service in one snapshot.
      mapfile -t run_files < <(watch_logs_latest_per_domain)
      if [[ "${#run_files[@]}" -gt 0 ]]; then
        echo "mode: latest-per-domain (fallback)"
      fi
    fi
    if [[ "${#run_files[@]}" -gt 0 ]]; then
      local file domain
      for file in "${run_files[@]}"; do
        domain="$(watch_logs_domain_from_file "$file")"
        if [[ -z "$domain" ]]; then
          domain="unknown"
        fi
        echo
        echo "${domain} log:"
        echo "  file=$file"
        tail -n 12 "$file" 2>/dev/null || true
      done
    else
      echo "logs: $(watch_status_label missing)"
    fi
  else
    echo "run_id: $(watch_status_label missing)"
  fi
  echo

  echo "service journal:"
  if command -v journalctl >/dev/null 2>&1; then
    service_lines="$(journalctl --user -u "$DAEMON_NAME" -n 12 --no-pager 2>/dev/null || true)"
    if [[ -n "$service_lines" ]]; then
      printf '%s\n' "$service_lines"
    else
      echo "  $(watch_status_label unavailable)"
    fi
  else
    echo "  journalctl not available"
  fi
}

watch_streaming_once() {
  require_cmd adb
  local serial stream_port status_json metrics_json
  local state profile encoder target_fps recv_fps present_fps decode_fps bitrate reverse_ok
  local idx
  local -a serials

  mapfile -t serials < <(android_connected_serials)
  printf '%-18s %-6s %-10s %-12s %-6s %-6s %-7s %-7s %-7s %-8s %-7s\n' \
    "serial" "port" "state" "profile" "t_fps" "r_fps" "p_fps" "d_fps" "kbps" "encoder" "reverse"
  printf '%-18s %-6s %-10s %-12s %-6s %-6s %-7s %-7s %-7s %-8s %-7s\n' \
    "------" "----" "-----" "-------" "-----" "-----" "-----" "-----" "----" "-------" "-------"

  if [[ "${#serials[@]}" -eq 0 ]]; then
    echo "no adb devices in state=device"
    return 0
  fi

  idx=1
  for serial in "${serials[@]}"; do
    stream_port="$(watch_device_stream_port "$idx")"
    status_json="$(watch_session_status_json "$serial" "$stream_port")"
    metrics_json="$(watch_session_metrics_json "$serial" "$stream_port")"

    state="$(json_string_field "$status_json" "state")"
    profile="$(json_string_field "$status_json" "profile")"
    encoder="$(json_string_field "$status_json" "encoder")"
    target_fps="$(json_scalar_field "$status_json" "fps")"
    recv_fps="$(json_scalar_field "$metrics_json" "recv_fps")"
    present_fps="$(json_scalar_field "$metrics_json" "present_fps")"
    decode_fps="$(json_scalar_field "$metrics_json" "decode_fps")"
    bitrate="$(json_scalar_field "$status_json" "bitrate_kbps")"
    reverse_ok="$(watch_adb_reverse_has_port "$serial" "$stream_port")"

    printf '%-18s %-6s %-10s %-12s %-6s %-6s %-7s %-7s %-7s %-8s %-7s\n' \
      "$serial" \
      "${stream_port}" \
      "$(watch_status_label "${state:-unknown}")" \
      "${profile:-unknown}" \
      "${target_fps:-?}" \
      "${recv_fps:-0}" \
      "${present_fps:-0}" \
      "${decode_fps:-0}" \
      "${bitrate:-?}" \
      "${encoder:-?}" \
      "$(watch_status_label "${reverse_ok:-no}")"
    idx=$((idx + 1))
  done
}

watch_health_once() {
  local code_health code_probe code_status
  code_health="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/health" || true)"
  code_probe="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/host-probe" || true)"
  code_status="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 1 "http://127.0.0.1:${CONTROL_PORT}/v1/status" || true)"
  printf 'endpoint /v1/health    http=%s\n' "$(watch_status_label "${code_health:-000}")"
  printf 'endpoint /v1/host-probe http=%s\n' "$(watch_status_label "${code_probe:-000}")"
  printf 'endpoint /v1/status    http=%s\n' "$(watch_status_label "${code_status:-000}")"
  echo
  watch_connections_once
}

watch_doctor_once() {
  local host_health="" host_build="" host_service="" file_build=""
  local serial api model apk_version expected reason
  local -a serials

  if host_health="$(host_health_raw)"; then
    host_build="$(json_string_field "$host_health" "build_revision")"
    host_service="$(json_string_field "$host_health" "service")"
    echo "host_health=reachable service=${host_service:-unknown} build_revision=${host_build:-unknown}"
  else
    echo "host_health=unreachable"
  fi

  file_build="$(build_version_read_file || true)"
  echo "build_file=${file_build:-<empty>} buildno=$(build_number_read_file || true)"
  if [[ -n "${WBEAM_BUILD_REV:-}" ]]; then
    echo "env_build_rev=${WBEAM_BUILD_REV}"
  else
    echo "env_build_rev=<unset>"
  fi

  if ! command -v adb >/dev/null 2>&1; then
    echo "adb=missing"
    return 0
  fi

  mapfile -t serials < <(android_connected_serials)
  if [[ "${#serials[@]}" -eq 0 ]]; then
    echo "adb_devices=none"
    return 0
  fi

  echo "adb_devices=${serials[*]}"
  for serial in "${serials[@]}"; do
    api="$(adb -s "$serial" shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r[:space:]' || true)"
    model="$(adb -s "$serial" shell getprop ro.product.model 2>/dev/null | tr -d '\r' || true)"
    apk_version="$(adb -s "$serial" shell dumpsys package "$ANDROID_PACKAGE" 2>/dev/null \
      | sed -n 's/^[[:space:]]*versionName=//p' | head -n 1 | tr -d '\r' || true)"
    expected="$host_build"
    if [[ -z "$expected" ]]; then
      expected="$file_build"
    fi
    if [[ -z "$apk_version" ]]; then
      reason="apk_not_installed"
    elif [[ -z "$expected" ]]; then
      reason="missing_expected_version"
    elif [[ "$apk_version" == "$expected" ]]; then
      reason="match"
    else
      reason="mismatch"
    fi
    printf '[%s] model=%s api=%s apk=%s expected=%s result=%s\n' \
      "$serial" "${model:-unknown}" "${api:-unknown}" "${apk_version:-<none>}" "${expected:-<none>}" "$reason"
  done
}

watch_collect_once() {
  local topic="$1"
  case "$topic" in
    devices)     watch_devices_once ;;
    connections) watch_connections_once ;;
    streaming)   watch_streaming_once ;;
    service)     watch_service_once ;;
    logs)        watch_logs_once ;;
    status)      watch_status_once ;;
    health)      watch_health_once ;;
    doctor)      watch_doctor_once ;;
    *)           echo "unknown watch topic: $topic"; return 1 ;;
  esac
}

watch_tui_topic_label() {
  case "$1" in
    devices) echo "1:devices" ;;
    connections) echo "2:connections" ;;
    streaming) echo "3:streaming" ;;
    service) echo "4:service" ;;
    logs) echo "5:logs" ;;
    *) echo "$1" ;;
  esac
}

watch_tui_loop() {
  local interval="${WBEAM_WATCH_INTERVAL:-1}"
  local topic="devices" key=""
  local footer

  while true; do
    clear || true
    watch_print_header "tui"
    echo "screen: $(watch_tui_topic_label "$topic")"
    echo
    watch_collect_once "$topic" || true
    echo
    footer="[1] devices  [2] connections  [3] streaming  [4] service  [5] logs   [r] refresh   [q] quit"
    printf '%s%s%s\n' "$(watch_style dim)" "$footer" "$(watch_style reset)"
    printf '%sactive=%s%s\n' "$(watch_style dim)" "$(watch_tui_topic_label "$topic")" "$(watch_style reset)"

    key=""
    IFS= read -rsn1 -t "$interval" key || true
    case "$key" in
      1) topic="devices" ;;
      2) topic="connections" ;;
      3) topic="streaming" ;;
      4) topic="service" ;;
      5) topic="logs" ;;
      q|Q) break ;;
      r|R) ;;
      *) ;;
    esac
  done
}

watch_run_loop() {
  local topic="$1"
  local mode="${2:-loop}"
  local interval="${WBEAM_WATCH_INTERVAL:-1}"
  local logfile=""
  local current_snapshot=""
  local last_snapshot=""
  local changed_count=0

  if [[ "$mode" == "once" ]]; then
    watch_print_header "$topic"
    watch_collect_once "$topic"
    return 0
  fi

  if [[ "${WBEAM_WATCH_LOG:-0}" == "1" ]]; then
    logfile="$(watch_log_file "$topic")"
    echo "[watch:$topic] logging enabled: $logfile"
  fi

  while true; do
    current_snapshot="$(watch_collect_once "$topic" 2>&1 || true)"
    if [[ "$current_snapshot" != "$last_snapshot" ]]; then
      changed_count=$((changed_count + 1))
      clear || true
      watch_print_header "$topic"
      printf '%schange detected%s (#%d)\n' "$(watch_style ok)" "$(watch_style reset)" "$changed_count"
      printf '%s\n' "$current_snapshot"
      if [[ -n "$logfile" ]]; then
        {
          watch_print_header "$topic"
          printf 'change detected (#%d)\n' "$changed_count"
          printf '%s\n' "$current_snapshot"
          echo
        } >>"$logfile"
      fi
      last_snapshot="$current_snapshot"
    else
      printf '\r%s[watch:%s]%s %s no changes' \
        "$(watch_style dim)" "$topic" "$(watch_style reset)" "$(date +%H:%M:%S)"
    fi
    sleep "$interval"
  done
}

