watch_adb_reverse_has_port() {
  local serial="$1"
  local port="$2"
  local rev
  rev="$(adb -s "$serial" reverse --list 2>/dev/null || true)"
  if [[ -n "$rev" ]] && printf '%s\n' "$rev" | grep -q "tcp:${port}[[:space:]]\+tcp:${port}"; then
    echo "yes"
  else
